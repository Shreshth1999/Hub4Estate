# Database (use your PostgreSQL connection string)
DATABASE_URL="postgresql://user:password@host:5432/hub4estate"

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (comma-separated for multiple origins)
# For Replit: use your replit app URL
# For localhost: http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Authentication Secrets (generate secure random strings)
SESSION_SECRET=change-this-to-random-string
JWT_SECRET=change-this-to-random-string

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Anthropic AI (optional - for AI features)
ANTHROPIC_API_KEY=

# Email (optional - for notifications)
RESEND_API_KEY=
NOTIFICATION_EMAIL=admin@example.com

# SMS - MSG91 (India) - Get from https://msg91.com
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# SMS - Twilio (International) - Get from https://twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Security Settings
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
