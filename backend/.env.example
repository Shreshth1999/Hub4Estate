# Database
DATABASE_URL="postgresql://user:password@localhost:5432/hub4estate"

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:3000

# Authentication Secrets (generate secure random strings — NEVER commit real values)
SESSION_SECRET=change-this-to-random-string
JWT_SECRET=change-this-to-random-string

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Anthropic AI (Claude API)
ANTHROPIC_API_KEY=

# OpenAI (embeddings for semantic search)
OPENAI_API_KEY=

# Encryption (64 hex chars = 32 bytes for AES-256-GCM field-level encryption)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# AWS S3 (file storage — presigned URLs, no express.static)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=hub4estate-uploads

# Redis (caching, rate limiting, sessions, queues)
REDIS_URL=redis://localhost:6379

# Razorpay (payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email (Resend)
RESEND_API_KEY=
NOTIFICATION_EMAIL=admin@hub4estate.com

# SMS - MSG91 (India)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# SMS - Twilio (fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Monitoring
SENTRY_DSN=
POSTHOG_API_KEY=

# Security Settings
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
