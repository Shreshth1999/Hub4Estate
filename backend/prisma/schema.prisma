generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), pg_trgm, uuid_ossp(map: "uuid-ossp")]
}

// ============================================
// USER MANAGEMENT
// ============================================

enum UserRole {
  INDIVIDUAL_HOME_BUILDER
  RENOVATION_HOMEOWNER
  ARCHITECT
  INTERIOR_DESIGNER
  CONTRACTOR
  ELECTRICIAN
  SMALL_BUILDER
  DEVELOPER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum ProfVerificationStatus {
  NOT_APPLIED
  PENDING_DOCUMENTS
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

model User {
  id            String      @id @default(uuid())
  email         String?     @unique
  googleId      String?     @unique
  phone         String?     @unique
  name          String
  role          UserRole?
  city          String?
  purpose       String?     // new build / renovation
  status        UserStatus  @default(ACTIVE)
  profileImage  String?
  isPhoneVerified Boolean   @default(false)
  isEmailVerified Boolean   @default(false)

  // Professional verification (for Architect, Interior Designer, Contractor etc.)
  profVerificationStatus ProfVerificationStatus @default(NOT_APPLIED)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  rfqs          RFQ[]
  communityPosts CommunityPost[]
  communityComments CommunityComment[]
  savedProducts SavedProduct[]
  professionalProfile ProfessionalProfile?

  @@index([email])
  @@index([phone])
  @@index([googleId])
  @@index([city])
  @@index([profVerificationStatus])
}

// Professional profile for Architects, Interior Designers, Contractors, Electricians
model ProfessionalProfile {
  id              String   @id @default(uuid())
  userId          String   @unique

  // Business info
  businessName    String?
  registrationNo  String?  // COA no (Architect), trade license no, etc.
  websiteUrl      String?
  portfolioUrl    String?
  bio             String?

  // Location
  officeAddress   String?
  city            String?
  state           String?
  pincode         String?

  // Years of experience
  yearsExperience Int?

  // Verification
  verifiedAt      DateTime?
  verifiedBy      String?   // Admin ID
  rejectionReason String?
  adminNotes      String?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents       ProfessionalDocument[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

// Documents uploaded by professionals for verification
model ProfessionalDocument {
  id          String   @id @default(uuid())
  profileId   String

  // Document details
  docType     String   // coa_certificate, trade_license, gst_certificate, id_proof, portfolio
  fileUrl     String
  fileName    String?
  fileSize    Int?     // bytes
  mimeType    String?

  isVerified  Boolean  @default(false)
  verifiedAt  DateTime?

  profile     ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([profileId])
  @@index([docType])
}

// OTP for phone/email verification
model OTP {
  id          String   @id @default(uuid())
  identifier  String   // phone number or email
  code        String   // 6-digit OTP
  type        String   // login, signup
  expiresAt   DateTime
  verified    Boolean  @default(false)
  attempts    Int      @default(0)

  createdAt   DateTime @default(now())

  @@index([identifier])
  @@index([expiresAt])
}

// ============================================
// DEALER MANAGEMENT
// ============================================

enum DealerStatus {
  PENDING_VERIFICATION
  DOCUMENTS_PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
  SUSPENDED
  DELETED
}

enum DealerType {
  RETAILER
  DISTRIBUTOR
  SYSTEM_INTEGRATOR
  CONTRACTOR
  OEM_PARTNER
  WHOLESALER
}

model Dealer {
  id                String        @id @default(uuid())
  email             String        @unique
  password          String?
  businessName      String
  ownerName         String
  phone             String
  gstNumber         String        @unique
  panNumber         String
  shopAddress       String
  city              String
  state             String
  pincode           String

  // Dealer classification
  dealerType        DealerType    @default(RETAILER)
  yearsInOperation  Int?

  // Verification documents
  gstDocument       String?
  panDocument       String?
  shopLicense       String?
  cancelledCheque   String?
  shopPhoto         String?
  shopImages        String[]      // Multiple shop/warehouse/product images
  brandAuthProofs   String[]      // Array of URLs

  // Storefront / public profile
  description       String?       @db.Text   // About the shop — public facing
  establishedYear   Int?          // Year business was established
  certifications    String[]      // e.g. ["ISI Authorized", "Havells Certified Dealer"]
  website           String?       // Optional website URL

  // Onboarding progress (0-100)
  onboardingStep    Int           @default(1)
  profileComplete   Boolean       @default(false)

  status            DealerStatus  @default(PENDING_VERIFICATION)
  verificationNotes String?
  verifiedAt        DateTime?
  verifiedBy        String?       // Admin ID
  rejectionReason   String?

  // Performance metrics
  totalRFQsReceived Int           @default(0)
  totalQuotesSubmitted Int        @default(0)
  totalConversions  Int           @default(0)
  conversionRate    Float         @default(0)
  avgResponseTime   Int?          // In minutes

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  brandMappings     DealerBrandMapping[]
  categoryMappings  DealerCategoryMapping[]
  serviceAreas      DealerServiceArea[]
  quotes            Quote[]
  reviews           DealerReview[]
  inquiryResponses  InquiryDealerResponse[]
  score             DealerScore?
  subscription      DealerSubscription?
  creditTransactions LeadCreditTransaction[]

  @@index([email])
  @@index([gstNumber])
  @@index([city])
  @@index([status])
}

model DealerServiceArea {
  id        String   @id @default(uuid())
  dealerId  String
  pincode   String
  dealer    Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([dealerId, pincode])
  @@index([pincode])
}

model DealerReview {
  id          String   @id @default(uuid())
  dealerId    String
  userId      String
  rfqId       String
  rating      Int      // 1-5
  comment     String?

  dealer      Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([dealerId])
  @@index([rfqId])
}

// ============================================
// PRODUCT CATALOG (Platform-Owned)
// ============================================

model Category {
  id          String        @id @default(uuid())
  name        String        @unique
  slug        String        @unique
  description String?
  icon        String?
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)

  // SEO & Education
  seoTitle    String?
  seoDescription String?
  whatIsIt    String?       // Explanation text
  whereUsed   String?       // Where in house
  whyQualityMatters String?
  commonMistakes String?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  subCategories SubCategory[]
  dealerMappings DealerCategoryMapping[]
  inquiries     ProductInquiry[]

  @@index([slug])
}

model SubCategory {
  id          String        @id @default(uuid())
  categoryId  String
  name        String
  slug        String
  description String?
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)

  category    Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  productTypes ProductType[]

  @@unique([categoryId, slug])
  @@index([slug])
}

model ProductType {
  id            String        @id @default(uuid())
  subCategoryId String
  name          String
  slug          String
  description   String?
  technicalInfo String?       // JSON string with technical details
  useCases      String?       // JSON array
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)

  subCategory   SubCategory   @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  products      Product[]

  @@unique([subCategoryId, slug])
  @@index([slug])
}

model Brand {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  logo        String?
  description String?
  website     String?
  isActive    Boolean  @default(true)
  isPremium   Boolean  @default(false)

  // Brand positioning
  priceSegment String? // Budget, Mid-range, Premium
  qualityRating Float? // 1-5

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  products    Product[]
  dealerMappings DealerBrandMapping[]
  brandDealers  BrandDealer[]
  identifiedInquiries ProductInquiry[]

  @@index([slug])
}

model Product {
  id            String      @id @default(uuid())
  productTypeId String
  brandId       String
  name          String
  modelNumber   String?
  sku           String?     @unique
  description   String?

  // Technical specifications (JSON)
  specifications String?   // Voltage, load, material, compliance standards, etc.

  // Media
  images        String[]    // Array of image URLs
  datasheetUrl  String?
  manualUrl     String?

  // Compliance & Warranty
  certifications String[]  // ISI, IEC, etc.
  warrantyYears Int?

  // Metadata
  isActive      Boolean     @default(true)

  productType   ProductType @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  brand         Brand       @relation(fields: [brandId], references: [id], onDelete: Cascade)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  rfqItems      RFQItem[]
  savedProducts SavedProduct[]

  @@index([brandId])
  @@index([productTypeId])
  @@index([sku])
}

model DealerBrandMapping {
  id              String   @id @default(uuid())
  dealerId        String
  brandId         String
  authProofUrl    String?  // URL to authorization document
  isVerified      Boolean  @default(false)

  dealer          Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  brand           Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@unique([dealerId, brandId])
  @@index([dealerId])
  @@index([brandId])
}

model DealerCategoryMapping {
  id          String   @id @default(uuid())
  dealerId    String
  categoryId  String

  dealer      Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([dealerId, categoryId])
  @@index([dealerId])
  @@index([categoryId])
}

// ============================================
// RFQ SYSTEM
// ============================================

enum RFQStatus {
  DRAFT
  PUBLISHED
  QUOTES_RECEIVED
  DEALER_SELECTED
  COMPLETED
  CANCELLED
}

model RFQ {
  id              String      @id @default(uuid())
  userId          String
  title           String
  description     String?

  // Location & Timeline
  deliveryCity    String
  deliveryPincode String
  deliveryAddress String?
  estimatedDate   DateTime?   // When user needs products

  // Preferences
  deliveryPreference String   // delivery, pickup, both
  urgency         String?     // normal, urgent

  status          RFQStatus   @default(DRAFT)
  publishedAt     DateTime?
  selectedDealerId String?
  selectedQuoteId  String?
  completedAt     DateTime?

  // AI-assisted data
  aiSuggestions   String?     // JSON with AI suggestions
  aiFlags         String?     // JSON with warnings/flags

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  items           RFQItem[]
  quotes          Quote[]

  @@index([userId])
  @@index([status])
  @@index([deliveryPincode])
  @@index([publishedAt])
}

model RFQItem {
  id          String   @id @default(uuid())
  rfqId       String
  productId   String
  quantity    Int
  notes       String?

  rfq         RFQ      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([rfqId])
  @@index([productId])
}

// ============================================
// QUOTE SYSTEM
// ============================================

enum QuoteStatus {
  SUBMITTED
  SELECTED
  REJECTED
  EXPIRED
}

model Quote {
  id              String      @id @default(uuid())
  rfqId           String
  dealerId        String

  // Pricing
  totalAmount     Float
  shippingCost    Float       @default(0)
  notes           String?

  // Timeline
  deliveryDate    DateTime?   // For delivery option
  pickupDate      DateTime?   // For pickup option
  validUntil      DateTime    // Quote expiry

  status          QuoteStatus @default(SUBMITTED)

  // Performance tracking
  submittedAt     DateTime    @default(now())
  viewedAt        DateTime?
  selectedAt      DateTime?

  // Loss analysis (if not selected)
  lossReason      String?     // price, timing, distance
  rankPosition    Int?        // Where this quote ranked

  rfq             RFQ         @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  dealer          Dealer      @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  items           QuoteItem[]

  @@unique([rfqId, dealerId])
  @@index([rfqId])
  @@index([dealerId])
  @@index([status])
}

model QuoteItem {
  id          String   @id @default(uuid())
  quoteId     String
  productId   String
  quantity    Int
  unitPrice   Float
  totalPrice  Float

  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([quoteId])
}

// ============================================
// COMMUNITY & KNOWLEDGE
// ============================================

enum PostStatus {
  PUBLISHED
  HIDDEN
  DELETED
}

model CommunityPost {
  id          String      @id @default(uuid())
  userId      String
  title       String
  content     String
  city        String?
  category    String?     // Discussion category
  tags        String[]

  upvotes     Int         @default(0)
  status      PostStatus  @default(PUBLISHED)

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  comments    CommunityComment[]
  votes       CommunityVote[]

  @@index([userId])
  @@index([city])
  @@index([status])
  @@index([createdAt])
}

model CommunityComment {
  id          String        @id @default(uuid())
  postId      String
  userId      String
  content     String
  parentId    String?       // For nested comments

  upvotes     Int           @default(0)

  post        CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      CommunityComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     CommunityComment[] @relation("CommentReplies")
  votes       CommunityVote[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([postId])
  @@index([userId])
  @@index([parentId])
}

model KnowledgeArticle {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String   // Rich text / Markdown
  category    String
  tags        String[]

  // SEO
  metaTitle   String?
  metaDescription String?

  // Media
  coverImage  String?

  views       Int      @default(0)
  isPublished Boolean  @default(false)

  authorId    String   // Admin ID

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt DateTime?

  @@index([slug])
  @@index([category])
  @@index([isPublished])
}

// ============================================
// USER INTERACTIONS
// ============================================

model SavedProduct {
  id          String   @id @default(uuid())
  userId      String
  productId   String
  notes       String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

// ============================================
// ADMIN & AUDIT
// ============================================

model Admin {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String
  role        String   @default("admin") // admin, super_admin
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
}

enum AuditAction {
  DEALER_VERIFIED
  DEALER_REJECTED
  DEALER_SUSPENDED
  PRODUCT_CREATED
  PRODUCT_UPDATED
  CATEGORY_CREATED
  USER_SUSPENDED
  RFQ_FLAGGED
  QUOTE_FLAGGED
  PAYMENT_PROCESSED
  SUBSCRIPTION_CHANGED
  CONVERSATION_FLAGGED
  ADMIN_SETTING_CHANGED
  FEATURE_FLAG_TOGGLED
}

// ============================================
// NEW ENUMS (PRD §6)
// ============================================

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
  GRACE_PERIOD
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
  TOOL_RESULT
}

enum DealerTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum NegotiationStatus {
  INIT
  ANALYZING
  COUNTER_OFFER_BUYER
  WAITING_DEALER
  COUNTER_OFFER_DEALER
  WAITING_BUYER
  AGREEMENT
  HUMAN_APPROVAL
  CONFIRMED
  REJECTED
  ABORTED
  TIMED_OUT
}

enum NegotiationStrategy {
  AGGRESSIVE
  BALANCED
  RELATIONSHIP_PRESERVING
}

enum AgentType {
  PROCUREMENT_COPILOT
  NEGOTIATION
  CHAT
  BOQ_GENERATOR
  PRICE_PREDICTOR
  CONVERSATION_INTEL
}

enum AgentSessionStatus {
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

model AuditLog {
  id          String      @id @default(uuid())
  action      AuditAction
  entityType  String      // dealer, product, rfq, etc.
  entityId    String
  performedBy String      // Admin ID
  details     String?     // JSON with additional info

  createdAt   DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([performedBy])
  @@index([createdAt])
}

// ============================================
// ANTI-FRAUD & SECURITY
// ============================================

model FraudFlag {
  id          String   @id @default(uuid())
  entityType  String   // user, dealer, rfq, quote
  entityId    String
  flagType    String   // duplicate_gst, fake_quote, spam_rfq, etc.
  severity    String   // low, medium, high, critical
  description String
  status      String   @default("open") // open, investigating, resolved, false_positive

  flaggedBy   String?  // System or admin ID
  resolvedBy  String?
  resolvedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([status])
  @@index([severity])
}

// ============================================
// CONTACT SUBMISSIONS (CRM/Leads)
// ============================================

model ContactSubmission {
  id          String    @id @default(uuid())
  name        String
  email       String
  phone       String?
  role        String    // homeowner, contractor, dealer, brand, other
  message     String    @db.Text
  source      String    @default("contact_form") // contact_form, ai_assistant, etc.

  // Status tracking
  status      String    @default("new") // new, contacted, qualified, converted, closed
  assignedTo  String?   // Admin ID
  notes       String?   @db.Text // Internal notes

  // Email tracking
  emailSent   Boolean   @default(false)
  emailSentAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// AI CHAT SESSIONS
// ============================================

model ChatSession {
  id            String    @id @default(uuid())

  // Optional user association
  userId        String?
  userEmail     String?   // For anonymous users who provide email
  userName      String?

  // Session metadata
  title         String?   // Auto-generated from first message
  status        String    @default("active") // active, closed

  // Analytics
  messageCount  Int       @default(0)
  lastMessageAt DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  messages      ChatMessage[]

  @@index([userId])
  @@index([userEmail])
  @@index([createdAt])
}

model ChatMessage {
  id          String      @id @default(uuid())
  sessionId   String

  role        String      // user, assistant
  content     String      @db.Text

  // Metadata
  tokenCount  Int?        // For tracking API usage

  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt   DateTime    @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

// ============================================
// B2B EMAIL TEMPLATES
// ============================================

model EmailTemplate {
  id           String   @id @default(uuid())
  name         String   @unique // internal name for selection
  subject      String
  body         String   @db.Text // HTML template with placeholders
  category     String   // outreach, follow_up, partnership, etc.

  // Placeholders: {{company_name}}, {{contact_name}}, {{custom_message}}
  placeholders String[] // List of available placeholders

  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
}

// ============================================
// CRM - COMPANY MANAGEMENT
// ============================================

enum CompanyType {
  MANUFACTURER
  DISTRIBUTOR
  DEALER
  BRAND
  OTHER
}

enum CompanySegment {
  PREMIUM
  MID_RANGE
  BUDGET
  ALL_SEGMENTS
}

model CRMCompany {
  id              String          @id @default(uuid())
  name            String
  slug            String          @unique
  type            CompanyType     @default(MANUFACTURER)
  segment         CompanySegment  @default(ALL_SEGMENTS)

  // Contact Info
  website         String?
  email           String?         // General company email
  phone           String?
  linkedIn        String?

  // Address
  address         String?
  city            String?
  state           String?
  country         String          @default("India")

  // Business Info
  description     String?         @db.Text
  productCategories String[]      // e.g., ["Wires", "MCBs", "Lighting"]
  yearEstablished Int?
  employeeCount   String?         // "1-50", "50-200", "200-500", "500+"
  annualRevenue   String?         // Revenue range

  // Digital Presence
  hasApi          Boolean         @default(false)
  digitalMaturity String?         // low, medium, high
  dealerNetworkSize String?       // small, medium, large

  // Status
  status          String          @default("prospect") // prospect, contacted, interested, partner, inactive
  priority        String          @default("medium")   // low, medium, high
  tags            String[]

  // Notes
  notes           String?         @db.Text

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  contacts        CRMContact[]
  outreaches      CRMOutreach[]

  @@index([status])
  @@index([type])
  @@index([segment])
  @@index([city])
}

// ============================================
// CRM - CONTACT MANAGEMENT
// ============================================

model CRMContact {
  id              String      @id @default(uuid())
  companyId       String
  company         CRMCompany  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Personal Info
  name            String
  email           String?
  phone           String?
  linkedIn        String?

  // Role Info
  designation     String?     // CEO, CTO, Head of Sales, etc.
  department      String?     // Sales, Technology, Marketing, Operations
  decisionMaker   Boolean     @default(false)
  isPrimary       Boolean     @default(false) // Primary contact for this company

  // Status
  status          String      @default("active") // active, left_company, do_not_contact

  // Notes
  notes           String?     @db.Text

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  outreaches      CRMOutreach[]

  @@index([companyId])
  @@index([email])
  @@index([designation])
}

// ============================================
// CRM - OUTREACH TRACKING
// ============================================

enum OutreachType {
  EMAIL
  LINKEDIN
  PHONE_CALL
  MEETING
  WHATSAPP
  OTHER
}

enum OutreachStatus {
  SCHEDULED
  SENT
  DELIVERED
  OPENED
  REPLIED
  MEETING_SCHEDULED
  NOT_INTERESTED
  BOUNCED
  FAILED
}

model CRMOutreach {
  id              String          @id @default(uuid())
  companyId       String
  contactId       String?
  company         CRMCompany      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact         CRMContact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  // Outreach Details
  type            OutreachType    @default(EMAIL)
  subject         String?
  content         String          @db.Text
  templateUsed    String?         // Email template name if used

  // Scheduling
  scheduledAt     DateTime?
  sentAt          DateTime?

  // Status & Tracking
  status          OutreachStatus  @default(SCHEDULED)
  openedAt        DateTime?
  repliedAt       DateTime?

  // Response
  responseContent String?         @db.Text
  responseSentiment String?       // positive, neutral, negative

  // Follow-up
  followUpDate    DateTime?
  followUpNumber  Int             @default(1) // 1st, 2nd, 3rd follow-up

  // Notes
  notes           String?         @db.Text

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([companyId])
  @@index([contactId])
  @@index([status])
  @@index([scheduledAt])
  @@index([type])
}

// ============================================
// CRM - MEETINGS
// ============================================

model CRMMeeting {
  id              String      @id @default(uuid())
  companyId       String
  title           String
  description     String?     @db.Text

  // Scheduling
  scheduledAt     DateTime
  duration        Int         @default(30) // minutes
  meetingLink     String?     // Zoom/Google Meet link
  location        String?

  // Attendees (stored as JSON array of {name, email, role})
  attendees       String?     @db.Text

  // Status
  status          String      @default("scheduled") // scheduled, completed, cancelled, rescheduled

  // Notes & Outcomes
  agenda          String?     @db.Text
  notes           String?     @db.Text  // Meeting notes
  outcome         String?     // positive, follow_up_needed, not_interested
  nextSteps       String?     @db.Text

  // Reminders (stored as JSON array of reminder times)
  reminders       String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([companyId])
  @@index([scheduledAt])
  @@index([status])
}

// ============================================
// CRM - PIPELINE STAGES
// ============================================

model CRMPipelineStage {
  id          String   @id @default(uuid())
  name        String   @unique // prospect, contacted, interested, negotiating, partner, churned
  displayName String
  color       String   // Hex color for UI
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

// ============================================
// PRODUCT INQUIRIES (Homepage Quick Form)
// ============================================

model ProductInquiry {
  id              String    @id @default(uuid())
  inquiryNumber   String?   @unique // HUB-HAVELLS-MCB-0001
  name            String
  phone           String
  email           String?
  productPhoto    String?   // Uploaded image path
  modelNumber     String?
  quantity        Int       @default(1)
  deliveryCity    String
  notes           String?   @db.Text

  // Status tracking
  status          String    @default("new") // new, contacted, quoted, closed
  assignedTo      String?   // Admin ID
  internalNotes   String?   @db.Text

  // Admin response (quote sent back to user)
  quotedPrice       Float?    // Price per unit
  shippingCost      Float?    // Shipping charges
  totalPrice        Float?    // Total including shipping
  estimatedDelivery String?   // e.g. "3-5 business days"
  responseNotes     String?   @db.Text
  respondedAt       DateTime?
  respondedBy       String?   // Admin ID who responded

  // NEW: Category identification
  categoryId          String?
  identifiedBrandId   String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  pipeline              InquiryPipeline?
  category              Category?               @relation(fields: [categoryId], references: [id])
  identifiedBrand       Brand?                  @relation(fields: [identifiedBrandId], references: [id])
  dealerResponses       InquiryDealerResponse[]

  @@index([status])
  @@index([phone])
  @@index([createdAt])
  @@index([inquiryNumber])
  @@index([categoryId])
}

// Dealer responses to product inquiries
model InquiryDealerResponse {
  id                String    @id @default(uuid())
  inquiryId         String
  dealerId          String

  status            String    @default("pending") // pending, viewed, quoted, declined
  quotedPrice       Float?
  shippingCost      Float?    @default(0)
  totalPrice        Float?
  estimatedDelivery String?
  notes             String?   @db.Text

  viewedAt          DateTime?
  respondedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  inquiry           ProductInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  dealer            Dealer         @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
  @@index([dealerId])
  @@index([status])
}

// ============================================
// INQUIRY PIPELINE (Dealer Quote Automation)
// ============================================

enum PipelineStatus {
  BRAND_IDENTIFIED
  DEALERS_FOUND
  QUOTES_REQUESTED
  QUOTES_RECEIVED
  SENT_TO_CUSTOMER
  CLOSED
}

enum QuoteResponseStatus {
  PENDING
  CONTACTED
  QUOTED
  NO_RESPONSE
  DECLINED
}

enum ContactMethod {
  WHATSAPP
  CALL
  EMAIL
  SMS
}

enum BrandDealerSource {
  MANUAL
  SCRAPED
  BRAND_WEBSITE
  PLATFORM_DEALER
}

// External dealer contacts (NOT platform-registered dealers)
model BrandDealer {
  id              String            @id @default(uuid())
  brandId         String
  brand           Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)

  name            String
  shopName        String?
  phone           String
  whatsappNumber  String?
  email           String?

  city            String
  state           String?
  pincode         String?
  address         String?

  source          BrandDealerSource @default(MANUAL)
  sourceUrl       String?
  isVerified      Boolean           @default(false)
  isActive        Boolean           @default(true)
  notes           String?           @db.Text

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  inquiryQuotes   InquiryDealerQuote[]

  @@unique([brandId, phone])
  @@index([brandId])
  @@index([city])
  @@index([isActive])
}

// One pipeline per inquiry - tracks admin workflow
model InquiryPipeline {
  id                  String          @id @default(uuid())
  inquiryId           String          @unique
  inquiry             ProductInquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  // AI-identified info
  identifiedBrandId   String?
  identifiedBrand     String?
  identifiedProduct   String?
  identifiedCategory  String?

  status              PipelineStatus  @default(BRAND_IDENTIFIED)

  // AI analysis result (JSON: brand confidence, product details, WhatsApp template)
  aiAnalysis          String?         @db.Text

  // Customer notification tracking
  sentToCustomerAt    DateTime?
  sentVia             String?         // email, sms, both
  customerMessage     String?         @db.Text

  createdBy           String?         // Admin ID

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  // Relations
  dealerQuotes        InquiryDealerQuote[]

  @@index([status])
  @@index([identifiedBrandId])
  @@index([createdAt])
}

// Each dealer contacted for a pipeline
model InquiryDealerQuote {
  id              String              @id @default(uuid())
  pipelineId      String
  pipeline        InquiryPipeline     @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  // Dealer reference (either external BrandDealer or platform Dealer)
  brandDealerId   String?
  brandDealer     BrandDealer?        @relation(fields: [brandDealerId], references: [id], onDelete: SetNull)
  dealerId        String?             // Platform dealer ID (no FK to keep it flexible)

  // Denormalized dealer info (for history even if dealer is deleted)
  dealerName      String
  dealerPhone     String
  dealerShopName  String?
  dealerCity      String?

  // Contact tracking
  contactMethod   ContactMethod       @default(WHATSAPP)
  contactedAt     DateTime?
  whatsappMessage String?             @db.Text

  // Quote details
  quotedPrice     Float?
  shippingCost    Float?
  totalQuotedPrice Float?
  deliveryDays    Int?
  warrantyInfo    String?
  quoteNotes      String?             @db.Text

  responseStatus  QuoteResponseStatus @default(PENDING)

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([pipelineId])
  @@index([brandDealerId])
  @@index([responseStatus])
}

// ============================================
// AUTH SECURITY TOKENS
// ============================================

// Persistent refresh tokens (mobile stays logged in; rotate on each use)
model RefreshToken {
  id          String    @id @default(uuid())
  token       String    @unique
  userId      String
  userType    String    // user, dealer, admin
  revoked     Boolean   @default(false)
  revokedAt   DateTime?
  expiresAt   DateTime

  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([revoked])
}

// Password reset tokens (time-limited, one-use)
model PasswordResetToken {
  id          String    @id @default(uuid())
  token       String    @unique
  email       String
  userType    String    // user, dealer
  used        Boolean   @default(false)
  expiresAt   DateTime

  createdAt   DateTime  @default(now())

  @@index([token])
  @@index([email])
  @@index([expiresAt])
}

// ============================================
// MOBILE PUSH NOTIFICATIONS
// ============================================

// Expo push tokens per device
model DevicePushToken {
  id          String    @id @default(uuid())
  token       String    @unique
  userId      String
  userType    String    // user, dealer
  platform    String    // ios, android
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([userType])
  @@index([isActive])
}

// In-app notification records
model Notification {
  id          String    @id @default(uuid())
  userId      String
  userType    String    // user, dealer
  title       String
  body        String
  data        String?   // JSON payload
  read        Boolean   @default(false)
  readAt      DateTime?

  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

// ============================================
// PRODUCT SCRAPING SYSTEM
// ============================================

enum ScrapeStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  PARTIAL
}

// Brand websites to scrape
model ScrapeBrand {
  id              String        @id @default(uuid())
  name            String        @unique
  slug            String        @unique
  website         String
  logoUrl         String?

  // Scraping configuration
  isActive        Boolean       @default(true)
  scrapeFrequency String        @default("weekly") // daily, weekly, monthly
  lastScrapedAt   DateTime?
  nextScrapeAt    DateTime?

  // Scraping URLs and selectors (JSON)
  catalogUrls     String?       @db.Text // JSON array of category URLs to scrape
  selectors       String?       @db.Text // JSON object with CSS selectors for product data

  // Stats
  totalProducts   Int           @default(0)
  lastScrapeCount Int           @default(0)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  scrapeJobs      ScrapeJob[]
  scrapedProducts ScrapedProduct[]

  @@index([slug])
  @@index([isActive])
}

// Individual scrape job runs
model ScrapeJob {
  id              String        @id @default(uuid())
  brandId         String
  brand           ScrapeBrand   @relation(fields: [brandId], references: [id], onDelete: Cascade)

  status          ScrapeStatus  @default(PENDING)
  startedAt       DateTime?
  completedAt     DateTime?

  // Results
  productsFound   Int           @default(0)
  productsCreated Int           @default(0)
  productsUpdated Int           @default(0)
  errors          Int           @default(0)

  // Logs
  logs            String?       @db.Text // JSON array of log entries
  errorDetails    String?       @db.Text // JSON array of error details

  // Configuration used
  configSnapshot  String?       @db.Text // JSON snapshot of selectors used

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([brandId])
  @@index([status])
  @@index([createdAt])
}

// Raw scraped product data (before normalization)
model ScrapedProduct {
  id              String        @id @default(uuid())
  brandId         String
  brand           ScrapeBrand   @relation(fields: [brandId], references: [id], onDelete: Cascade)

  // Source info
  sourceUrl       String        @db.Text
  scrapedAt       DateTime      @default(now())

  // Raw data
  rawName         String
  rawCategory     String?
  rawSubCategory  String?
  rawModelNumber  String?
  rawSku          String?
  rawDescription  String?       @db.Text
  rawSpecifications String?     @db.Text // JSON object of all specs
  rawImages       String[]      // Array of image URLs
  rawDatasheetUrl String?
  rawManualUrl    String?
  rawPrice        String?       // MRP if available
  rawCertifications String[]
  rawWarranty     String?

  // Processing status
  isProcessed     Boolean       @default(false)
  processedAt     DateTime?
  productId       String?       // Link to normalized Product if created

  // Validation
  isValid         Boolean       @default(true)
  validationErrors String?      @db.Text // JSON array of validation issues

  // Deduplication
  contentHash     String?       // Hash of key fields for deduplication

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([brandId])
  @@index([isProcessed])
  @@index([contentHash])
  @@index([rawModelNumber])
  @@index([sourceUrl])
}

// Scraping rules for mapping raw data to categories
model ScrapeMapping {
  id              String   @id @default(uuid())

  // Matching rules
  brandPattern    String?  // Regex pattern for brand name
  categoryPattern String?  // Regex pattern for raw category
  namePattern     String?  // Regex pattern for product name

  // Target mapping
  targetCategoryId    String?
  targetSubCategoryId String?
  targetProductTypeId String?

  // Priority (higher = checked first)
  priority        Int      @default(0)
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([priority])
  @@index([isActive])
}

// Scraping configuration templates
model ScrapeTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?

  // Common selectors (JSON)
  selectors   String   @db.Text

  // Brands using this template
  brandIds    String[] // Array of brand IDs

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// USER ACTIVITY TRACKING (Comprehensive Log)
// ============================================

enum ActivityType {
  // Auth events
  USER_SIGNUP
  USER_LOGIN
  USER_GOOGLE_SIGNIN
  USER_GOOGLE_SIGNUP
  USER_PROFILE_COMPLETED
  USER_OTP_REQUESTED
  USER_OTP_VERIFIED

  // Dealer events
  DEALER_REGISTERED
  DEALER_LOGIN
  DEALER_PROFILE_UPDATED
  DEALER_DOCUMENT_UPLOADED
  DEALER_DOCUMENT_DELETED
  DEALER_BRAND_ADDED
  DEALER_CATEGORY_ADDED
  DEALER_SERVICE_AREA_ADDED
  DEALER_SERVICE_AREA_REMOVED
  DEALER_VERIFIED
  DEALER_REJECTED

  // Product events
  PRODUCT_INQUIRY_SUBMITTED
  PRODUCT_IMAGE_UPLOADED
  MODEL_NUMBER_SUBMITTED
  PRODUCT_SAVED
  PRODUCT_SEARCHED

  // RFQ events
  RFQ_CREATED
  RFQ_PUBLISHED
  RFQ_CANCELLED

  // Quote events
  QUOTE_SUBMITTED
  QUOTE_SELECTED

  // Community events
  POST_CREATED
  COMMENT_CREATED
  POST_UPVOTED

  // Contact events
  CONTACT_FORM_SUBMITTED

  // Chat events
  CHAT_SESSION_STARTED
  CHAT_MESSAGE_SENT

  // Admin events
  ADMIN_LOGIN
}

model UserActivity {
  id            String       @id @default(uuid())

  // Who performed the action
  actorType     String       // user, dealer, admin, anonymous
  actorId       String?      // User/Dealer/Admin ID (null for anonymous)
  actorEmail    String?      // Email if available
  actorName     String?      // Name if available

  // What happened
  activityType  ActivityType
  description   String       // Human-readable description

  // Context data (JSON) - stores relevant details
  metadata      String?      @db.Text // JSON: product details, model numbers, image paths, etc.

  // Related entity
  entityType    String?      // user, dealer, product, rfq, quote, inquiry, etc.
  entityId      String?      // ID of the related entity

  // Request context
  ipAddress     String?
  userAgent     String?

  createdAt     DateTime     @default(now())

  @@index([actorType, actorId])
  @@index([activityType])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([actorEmail])
}

// ============================================
// USER PREFERENCES
// ============================================

model UserPreference {
  id                    String   @id @default(uuid())
  userId                String   @unique
  language              String   @default("en") // en, hi, ta, te, kn, bn
  notifyEmail           Boolean  @default(true)
  notifySms             Boolean  @default(true)
  notifyWhatsapp        Boolean  @default(true)
  notifyPush            Boolean  @default(true)
  marketingEmails       Boolean  @default(false)
  analyticsConsent      Boolean  @default(false)
  thirdPartyConsent     Boolean  @default(false)
  digestFrequency       String   @default("daily") // realtime, daily, weekly, none

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
}

// ============================================
// DEALER SCORING & SUBSCRIPTIONS
// ============================================

model DealerScore {
  id                  String     @id @default(uuid())
  dealerId            String     @unique
  responseSpeed       Float      @default(0) // 0-100
  priceCompetitiveness Float     @default(0) // 0-100
  reliability         Float      @default(0) // 0-100
  volume              Float      @default(0) // 0-100
  compositeScore      Float      @default(0) // 0-100
  tier                DealerTier @default(BRONZE)
  totalQuotes         Int        @default(0)
  totalWins           Int        @default(0)
  avgResponseMinutes  Float?
  lastCalculatedAt    DateTime   @default(now())

  dealer              Dealer     @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@index([compositeScore])
  @@index([tier])
}

model SubscriptionPlan {
  id                String   @id @default(uuid())
  name              String   @unique // starter, growth, premium, enterprise
  displayName       String
  priceMonthlyPaise Int      // Price in paise (e.g. 99900 = ₹999)
  priceYearlyPaise  Int?
  leadsPerMonth     Int
  quotesPerMonth    Int
  features          String[] // Feature list for display
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subscriptions     DealerSubscription[]

  @@index([isActive])
}

model DealerSubscription {
  id                  String             @id @default(uuid())
  dealerId            String             @unique
  planId              String
  status              SubscriptionStatus @default(ACTIVE)
  razorpaySubId       String?            @unique
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  cancelledAt         DateTime?
  cancelReason        String?
  leadsUsed           Int                @default(0)
  quotesUsed          Int                @default(0)

  dealer              Dealer             @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  plan                SubscriptionPlan   @relation(fields: [planId], references: [id])

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([dealerId])
  @@index([status])
  @@index([currentPeriodEnd])
}

model LeadCreditTransaction {
  id            String   @id @default(uuid())
  dealerId      String
  amount        Int      // positive = credit, negative = debit
  type          String   // purchase, deduction, refund, bonus
  balanceAfter  Int
  description   String?
  referenceId   String?  // payment ID or inquiry ID
  referenceType String?  // payment, inquiry

  dealer        Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())

  @@index([dealerId])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// PRICE DATA & INTELLIGENCE
// ============================================

model PriceDataPoint {
  id            String   @id @default(uuid())
  productId     String?
  brandId       String?
  categoryId    String?
  city          String?
  source        String   // dealer_quote, scrape_amazon, scrape_flipkart, manual
  pricePaise    Int      // Price in paise
  mrpPaise      Int?
  unit          String   @default("piece")
  dealerId      String?
  sourceUrl     String?

  createdAt     DateTime @default(now())

  @@index([productId, createdAt])
  @@index([brandId, categoryId])
  @@index([city, createdAt])
  @@index([source])
}

model PriceTrend {
  id                String   @id @default(uuid())
  productId         String?
  categoryId        String?
  city              String?
  period            String   // weekly, monthly
  avgPricePaise     Int
  minPricePaise     Int
  maxPricePaise     Int
  medianPricePaise  Int
  p25PricePaise     Int
  p75PricePaise     Int
  quoteCount        Int
  trendDirection    String?  // up, down, stable
  changePercent     Float?
  periodStart       DateTime
  periodEnd         DateTime

  createdAt         DateTime @default(now())

  @@unique([productId, city, period, periodStart])
  @@index([categoryId, period])
  @@index([periodStart])
}

model PredictedPrice {
  id              String   @id @default(uuid())
  productId       String
  city            String
  predictedPaise  Int
  confidenceLow   Int
  confidenceHigh  Int
  confidenceScore Float    // 0-1
  model           String   // xgboost_v1, etc.
  features        String?  @db.Text // JSON: input features used
  recommendation  String?  // buy_now, wait, neutral
  validUntil      DateTime

  createdAt       DateTime @default(now())

  @@index([productId, city])
  @@index([validUntil])
}

// ============================================
// MESSAGING SYSTEM
// ============================================

model Conversation {
  id            String    @id @default(uuid())
  title         String?
  type          String    @default("direct") // direct, inquiry, negotiation
  referenceId   String?   // inquiry ID, negotiation ID, etc.
  referenceType String?   // inquiry, negotiation, rfq

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  participants  ConversationParticipant[]
  messages      Message[]

  @@index([referenceId, referenceType])
}

model ConversationParticipant {
  id              String       @id @default(uuid())
  conversationId  String
  accountId       String       // user or dealer ID
  accountType     String       // user, dealer, admin
  lastReadAt      DateTime?
  isMuted         Boolean      @default(false)

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt       DateTime     @default(now())

  @@unique([conversationId, accountId])
  @@index([accountId, accountType])
}

model Message {
  id              String       @id @default(uuid())
  conversationId  String
  senderId        String
  senderType      String       // user, dealer, admin, system
  type            MessageType  @default(TEXT)
  content         String       @db.Text
  metadata        String?      @db.Text // JSON: image URL, tool result, etc.
  isEdited        Boolean      @default(false)

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ============================================
// COMMUNITY VOTES
// ============================================

model CommunityVote {
  id          String         @id @default(uuid())
  userId      String
  postId      String?
  commentId   String?
  value       Int            // +1 or -1

  post        CommunityPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment     CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt   DateTime       @default(now())

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([commentId])
}

// ============================================
// PAYMENT & INVOICES
// ============================================

model Payment {
  id                  String        @id @default(uuid())
  orderId             String?       // Internal order reference
  razorpayOrderId     String?       @unique
  razorpayPaymentId   String?       @unique
  razorpaySignature   String?
  amount              Int           // In paise
  currency            String        @default("INR")
  status              PaymentStatus @default(PENDING)
  method              String?       // upi, card, netbanking, wallet
  payerAccountId      String        // user or dealer ID
  payerAccountType    String        // user, dealer
  description         String?
  metadata            String?       @db.Text // JSON
  failureReason       String?
  refundedAmount      Int?
  refundedAt          DateTime?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  invoice             Invoice?

  @@index([payerAccountId, payerAccountType])
  @@index([status])
  @@index([razorpayOrderId])
  @@index([createdAt])
}

model Invoice {
  id              String   @id @default(uuid())
  paymentId       String   @unique
  invoiceNumber   String   @unique // H4E-INV-2026-0001
  buyerName       String
  buyerGstin      String?
  buyerAddress    String?
  sellerName      String   @default("HUB4ESTATE LLP")
  sellerGstin     String   @default("PENDING") // To be updated after GST registration
  items           String   @db.Text // JSON array of line items
  subtotalPaise   Int
  cgstPaise       Int
  sgstPaise       Int
  igstPaise       Int      @default(0)
  totalPaise      Int
  sacCode         String   @default("998314")
  isInterState    Boolean  @default(false)
  pdfUrl          String?  // S3 key

  payment         Payment  @relation(fields: [paymentId], references: [id])

  createdAt       DateTime @default(now())

  @@index([invoiceNumber])
  @@index([paymentId])
  @@index([createdAt])
}

// ============================================
// PLATFORM SETTINGS & FEATURE FLAGS
// ============================================

model PlatformSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("string") // string, number, boolean, json
  description String?
  updatedBy   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model FeatureFlag {
  id            String   @id @default(uuid())
  key           String   @unique
  name          String
  description   String?
  isEnabled     Boolean  @default(false)
  rolloutPercent Int     @default(0) // 0-100 for gradual rollout
  targetRoles   String[] // empty = all roles
  updatedBy     String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([key])
  @@index([isEnabled])
}

// ============================================
// SEARCH & ANALYTICS
// ============================================

model SearchHistory {
  id          String   @id @default(uuid())
  userId      String?
  query       String
  filters     String?  @db.Text // JSON
  resultCount Int      @default(0)
  clickedId   String?  // product/dealer ID clicked
  sessionId   String?

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([query])
  @@index([createdAt])
}

// ============================================
// AI / AGENTIC SYSTEMS
// ============================================

model AgentSession {
  id                 String             @id @default(uuid())
  userId             String?
  dealerId           String?
  agentType          AgentType
  status             AgentSessionStatus @default(ACTIVE)
  context            String?            @db.Text // JSON: conversation context
  totalInputTokens   Int                @default(0)
  totalOutputTokens  Int                @default(0)
  totalCostUsd       Float              @default(0)
  messageCount       Int                @default(0)

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  messages           AgentMessage[]
  negotiation        NegotiationSession?

  @@index([userId, status])
  @@index([dealerId, status])
  @@index([agentType, status])
  @@index([status])
}

model AgentMessage {
  id            String       @id @default(uuid())
  sessionId     String
  role          String       // user, assistant, system, tool
  content       String       @db.Text
  toolName      String?
  toolInput     String?      @db.Text // JSON
  toolOutput    String?      @db.Text // JSON
  model         String?      // claude-sonnet-4-20250514, claude-haiku-4-5-20251001, etc.
  inputTokens   Int?
  outputTokens  Int?
  latencyMs     Int?

  session       AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt     DateTime     @default(now())

  @@index([sessionId, createdAt])
}

model AITokenUsage {
  id            String   @id @default(uuid())
  userId        String?
  dealerId      String?
  agentType     String
  model         String
  inputTokens   Int
  outputTokens  Int
  cacheHit      Boolean  @default(false)
  latencyMs     Int?
  costUsd       Float?
  sessionId     String?

  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([dealerId, createdAt])
  @@index([agentType, createdAt])
  @@index([model, createdAt])
}

model AICache {
  id          String   @id @default(uuid())
  promptHash  String   @unique // SHA-256
  agentType   String
  model       String
  response    String   @db.Text
  expiresAt   DateTime

  createdAt   DateTime @default(now())

  @@index([promptHash])
  @@index([expiresAt])
}

// ============================================
// NEGOTIATION SYSTEM
// ============================================

model NegotiationSession {
  id                  String              @id @default(uuid())
  inquiryId           String?
  quoteId             String?
  buyerId             String?
  dealerId            String?
  agentSessionId      String?             @unique
  status              NegotiationStatus   @default(INIT)
  strategy            NegotiationStrategy @default(BALANCED)

  // BATNA / ZOPA / Nash
  buyerBatna          Int?                // Paise
  dealerBatna         Int?                // Paise
  zopaMin             Int?                // Paise
  zopaMax             Int?                // Paise
  nashPrice           Int?                // Paise
  targetPrice         Int?                // Paise
  walkawayPrice       Int?                // Paise

  // Round tracking
  maxRounds           Int                 @default(4)
  currentRound        Int                 @default(0)
  initialQuotePrice   Int?                // Paise
  finalAgreedPrice    Int?                // Paise
  savingsAmount       Int?                // Paise
  savingsPercent      Float?

  timeoutAt           DateTime?
  completedAt         DateTime?

  agentSession        AgentSession?       @relation(fields: [agentSessionId], references: [id])
  rounds              NegotiationRound[]

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([inquiryId])
  @@index([buyerId, status])
  @@index([dealerId, status])
  @@index([status])
}

model NegotiationRound {
  id                String             @id @default(uuid())
  negotiationId     String
  roundNumber       Int
  offeredBy         String             // buyer, dealer, agent
  offeredPrice      Int                // Paise
  offeredDeliveryDays Int?
  justification     String?            @db.Text
  strategyUsed      String?
  response          String?            // accept, counter, reject
  responseAt        DateTime?
  responseMessage   String?            @db.Text
  agentReasoning    String?            @db.Text // JSON

  negotiation       NegotiationSession @relation(fields: [negotiationId], references: [id], onDelete: Cascade)

  createdAt         DateTime           @default(now())

  @@index([negotiationId, roundNumber])
}

// ============================================
// SCRAPED PRICE POINTS & COMMODITIES
// ============================================

model ScrapedPricePoint {
  id              String   @id @default(uuid())
  source          String   // amazon, flipkart, indiamart, brand_website
  sourceUrl       String?  @db.Text
  sourceProductId String?
  contentHash     String?
  productName     String
  brandName       String?
  modelNumber     String?
  categorySlug    String?
  pricePaise      Int
  mrpPaise        Int?
  unit            String   @default("piece")
  currency        String   @default("INR")
  city            String?
  sellerName      String?
  inStock         Boolean? @default(true)
  rawData         String?  @db.Text // JSON
  scrapedAt       DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  isUpdate        Boolean  @default(false)

  @@index([source, scrapedAt])
  @@index([brandName, modelNumber])
  @@index([categorySlug])
  @@index([contentHash])
}

model CommodityPrice {
  id          String   @id @default(uuid())
  commodity   String   // copper, aluminum, steel, pvc
  source      String   // mcx, lme, government_portal
  pricePaise  Int
  unit        String   // kg, ton, meter
  currency    String   @default("INR")
  date        DateTime @db.Date

  createdAt   DateTime @default(now())

  @@unique([commodity, source, date])
  @@index([commodity, date])
}
